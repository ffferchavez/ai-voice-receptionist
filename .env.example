# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional shared-auth cookie config (production multi-subdomain setups)
# NEXT_PUBLIC_SITE_URL=https://example.com
# NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.example.com

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
# Preferred public key:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Legacy fallback:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: never expose to the browser. Used for webhook ingestion & admin writes.
SUPABASE_SERVICE_ROLE_KEY=
# Optional override when using non-default schema routing in app code.
# SUPABASE_VOICES_SCHEMA=voices

# OpenAI (Phase 5 — structured extraction & summaries)
OPENAI_API_KEY=

# Anthropic — Claude Opus 4.6 drives the AI conversation brain
ANTHROPIC_API_KEY=

# ElevenLabs — TTS (voice synthesis) + STT (Scribe transcription)
ELEVENLABS_API_KEY=
# Optional: default ElevenLabs voice ID (Rachel = 21m00Tcm4TlvDq8ikWAM)
# ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Other voice providers (configure per org in DB; optional global fallbacks for dev)
# VAPI_API_KEY=
